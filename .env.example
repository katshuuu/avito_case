# Copy this file to .env and set values for local run.
APP_NAME=project_name
DEFAULT_CATEGORY=other
INPUT_PATH=data/raw/input.json
OUTPUT_PATH=artifacts/predictions/predictions.json

# Optional: remote LLM for draft text only (no local model hosting)
# OPENAI_API_KEY=
# ENABLE_LLM_DRAFTS=0
# OPENAI_API_BASE=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_TIMEOUT_S=2.5
